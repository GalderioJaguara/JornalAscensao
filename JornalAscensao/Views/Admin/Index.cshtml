@model AdminDashboardViewModel
@{
    ViewBag.Title = "title";
    Layout = "_AdminLayout";
}
<div class="admin-container">
    <header class="h-25">
        <div class="p-3 d-flex align-items-center gap-2 border-bottom">
            <button onclick="toggleSideNav()" class="btn btn-secondary border-0"><span><i class="bi bi-grid-1x2"></i></span></button>
            <h2 class="fs-5 m-0">Painel</h2>
        </div>
    </header>
    <main class="p-4">
        @* Cards *@
        <div class="row">
            <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <h3 class="fs-6">Pautas Abertas</h3>
                            <span><i class="bi bi-exclamation-circle fs-5"></i></span>
                        </div>
                        <div>
                            <span class="fs-4 fw-bold">@Model.PautasAbertas</span>
                        </div>
                        <div class="text-muted small">
                            <span>Aguardando desenvolvimento</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <h3 class="fs-6">Artigos na fila</h3>
                            <span><i class="bi bi-exclamation-circle fs-5"></i></span>
                        </div>
                        <div>
                            <span class="fs-4 fw-bold">@Model.ArtigosFila</span>
                        </div>
                        <div class="text-muted small">
                            <span>Artigos aguardando revisão</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <h3 class="fs-6">Pautas Fechadas</h3>
                            <span><i class="bi bi-exclamation-circle fs-5"></i></span>
                        </div>
                        <div>
                            <span class="fs-4 fw-bold">@Model.PautasFechadas</span>
                        </div>
                        <div class="text-muted small">
                            <span>Pautas concluídas</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 col-sm-12 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <h3 class="fs-6">Artigos publicados</h3>
                            <span><i class="bi bi-exclamation-circle fs-5"></i></span>
                        </div>
                        <div>
                            <span class="fs-4 fw-bold">@Model.ArtigosPublicados</span>
                        </div>
                        <div class="text-muted small">
                            <span>total no sistema</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        
        <div class="mt-4 row">
            <div class="col-lg-6 col-md-12 mb-3">
                <div class="card h-100">
                    <div class="px-3 pt-3">
                        <h3>Colaboradores</h3>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span> Novos Colaboradores</span>
                            <span class="card-ball ball-primary">@Model.NovosColaboradores</span>
                        </div>
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <span>Colaboradores bloqueados</span>
                            <span class="card-ball ball-secondary">@Model.ColaboradoresBloqueados</span>
                        </div>
                        
                    </div>
                    
                </div>
            </div>
        </div>

    </main>
</div>
